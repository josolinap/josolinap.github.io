# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Multi-LLM Provider API Keys (configure as needed)
# Free providers (always available):
VITE_HUGGINGFACE_API_KEY=your-huggingface-api-key  # Optional for enhanced models
VITE_REPLICATE_API_KEY=your-replicate-api-key      # Required for Replicate free tier

# Paid providers - choose one or more:
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key

# Cloudflare Worker (for production - auto-loads when available)
VITE_WORKER_URL=https://ai-notes-proxy.nosleep.workers.dev

# Model Preferences (optional - defaults provided)
VITE_HUGGINGFACE_MODEL=microsoft/DialoGPT-medium
VITE_REPLICATE_MODEL=meta/llama-2-7b-chat
VITE_GEMINI_MODEL=gemini-1.5-flash
VITE_OPENAI_MODEL=gpt-4
VITE_ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Admin Password (optional, defaults to admin123)
VITE_ADMIN_PASSWORD=your-admin-password

# System Configuration
VITE_ENVIRONMENT=development  # development | production
VITE_AGENT_MEMORY_SIZE=100    # Max memory logs to keep
VITE_CONVERSATION_HISTORY=50  # Max conversation messages
